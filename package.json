{
  "name": "tatufa",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "cd api && MQTT_MODE=mock python3 -m uvicorn server:app --reload --host 0.0.0.0 --port 6001",
    "dev": "concurrently -c \"cyan,magenta\" -n \"REACT,PYTHON\" \"npm run dev:frontend\" \"npm run dev:backend\"",
