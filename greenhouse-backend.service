[Unit]
Description=Tatufa Backend API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/home/Apps/GreenhouseLucor/api
Environment=MQTT_MODE=mock
Environment=MQTT_BROKER=localhost
ExecStart=/usr/bin/python3 -m uvicorn server:app --host 0.0.0.0 --port 6001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
